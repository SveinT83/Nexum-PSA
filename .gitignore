# Operating system noise
.DS_Store
Thumbs.db

# Local environment and secrets
.env
.env.*
!.env.example
/auth.json
/storage/*.key

# PHP and Laravel dependencies/cache
/vendor
/.phpunit.cache
.phpunit.result.cache
.phpactor.json
/bootstrap/cache/*.php
!/bootstrap/cache/.gitignore

# Frontend dependencies/build output
/node_modules
/public/build
/public/hot
/public/storage

# Runtime storage generated by Laravel
/storage/app/*
!/storage/app/.gitignore
!/storage/app/private/
!/storage/app/public/
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
!/storage/framework/cache/data/
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore
/storage/pail

# Generated API/documentation output
/storage/api-docs/*.json
/public/docs
/coverage

# IDE/editor local state
/.fleet
/.idea
/.nova
/.vscode
/.zed

# Local VM tooling
Homestead.json
Homestead.yaml

# Assistant and local planning scratch files. Keep shared docs in /docs tracked;
# use the folders below for private drafts that should not ship.
/.aiassistant/
/docs/tmp/
/docs/drafts/
/docs/local/
/**/*.blade.md
/app/Modules/**/Controllers/**/*.md
/app/Modules/**/Views/**/*.md
/resources/views/**/*.md
/routes/*.md

# Logs
*.log
